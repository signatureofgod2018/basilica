# AI Board Room — Production Environment (ST-GABRIEL)
# Copy to .env on ST-GABRIEL at /opt/boardroom/.env

# PostgreSQL
POSTGRES_USER=boardroom
POSTGRES_PASSWORD=<strong-password-here>

# Anthropic (Claude connector)
ANTHROPIC_API_KEY=

# GitHub (Copilot connector)
GITHUB_TOKEN=

# GitHub Container Registry (for pulling images)
GHCR_TOKEN=<github-pat-with-read-packages-scope>
